    font-size: 1.25rem;
  }
  .nav {
    display: flex;
    gap: 1.5rem;
  }
  .nav a {
    text-decoration: none;
    color: #475569;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .nav a:hover {
    color: #0f172a;
  }
