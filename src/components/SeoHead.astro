---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { 
  title = "補助金SaaSマッチャー", 
  description = "補助金とSaaSを自動マッチング",
  canonical
} = Astro.props;

const siteTitle = title.includes("補助金SaaSマッチャー") ? title : `${title} | 補助金SaaSマッチャー`;
const base = import.meta.env.BASE_URL;
---

<!-- SEO Meta Tags -->
<title>{siteTitle}</title>
<meta name="description" content={description} />
<meta charset="utf-8" />
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<meta name="google-site-verification" content="_-l2L3a9sescPeoitkfmbJZCmVDDmYZCFmE6k3Dcv0E" />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;700&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">

{canonical && <link rel="canonical" href={canonical} />}

<!-- OGP -->
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta name="twitter:card" content="summary_large_image" />
