---
import SeoHead from '../components/SeoHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<html lang="ja">
  <head>
    <SeoHead title={title} description={description} canonical={canonical} />
  </head>
  <body>
    <!-- Decorative background elements -->
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>
    
    <div class="layout-wrapper">
      <Header />
      <main class="main-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  body {
    position: relative;
    overflow-x: hidden;
  }
  
  .layout-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  
  .main-content {
    flex: 1;
    width: 100%;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }
  
  /* Abstract modern background shapes */
  .bg-shape {
    position: absolute;
    filter: blur(100px);
    z-index: 0;
    border-radius: 50%;
    opacity: 0.4;
    pointer-events: none;
  }
  
  .shape-1 {
    top: -10%;
    right: -5%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, rgba(96,165,250,0.8) 0%, rgba(59,130,246,0) 70%);
  }
  
  .shape-2 {
    bottom: 10%;
    left: -10%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, rgba(167,139,250,0.6) 0%, rgba(139,92,246,0) 70%);
  }
</style>
