---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;

const dataPath = path.join(process.cwd(), 'data', 'tools.json');
let tools = [];
try {
  tools = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load tools", e);
}

const sortedTools = tools.sort((a, b) => (b.priority_score || 0) - (a.priority_score || 0));
---

<BaseLayout title="推奨ツール一覧 | 補助金SaaSマッチャー">
  <div class="container py-12">
    <h1 class="text-3xl font-bold mb-8">推奨サービス一覧</h1>
    <div class="grid md:grid-cols-3 gap-6">
      {sortedTools.map(t => (
        <div class="glass-card">
          <span class="category-tag">{t.category}</span>
          <h3 class="mt-4 mb-2"><a href={`${base}tools/${t.slug}/`}>{t.name}</a></h3>
          <p class="text-sm text-secondary mb-4">{t.strengths}</p>
          <a href={t.affiliate_url} target="_blank" rel="sponsored noopener" class="btn btn-primary btn-sm w-full">公式サイト</a>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
