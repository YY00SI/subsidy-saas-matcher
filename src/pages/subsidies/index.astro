---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatCurrency } from '../../lib/normalize';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;

const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsidies", e);
}

const tagMap: Record<string, string> = {
  'accounting': '経理・会計',
  'invoice': 'インボイス・請求',
  'expense': '経費精算',
  'payroll': '給与・労務',
  'pos': 'POSレジ'
};

function translateTag(tag: string) {
  return tagMap[tag] || tag;
}
---

<BaseLayout title="補助金一覧 | 補助金SaaSマッチャー">
  <div class="container" style="max-width:860px; margin:0 auto; padding:2.5rem 1.5rem 4rem;">

    <div style="margin-bottom:2rem;">
      <p style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.5rem;">
        <a href={base} style="color:var(--accent);">TOP</a> &rsaquo; 補助金一覧
      </p>
      <h1 style="font-size:1.75rem; font-weight:800; color:var(--primary); margin:0 0 0.5rem;">補助金一覧</h1>
      <p style="color:var(--text-muted); font-size:0.95rem;">{subsidies.length}件の補助金が見つかりました。SaaSツール導入に活用できる補助金を厳選しています。</p>
    </div>

    <div style="display:flex; flex-direction:column; gap:1rem;">
      {subsidies.map(s => (
        <a href={`${base}subsidies/${s.id}/`} style="display:block; text-decoration:none;" class="subsidy-row-link">
          <div class="glass-card" style="padding:1.25rem 1.5rem; display:flex; justify-content:space-between; align-items:center; gap:1rem;">
            <div style="flex:1; min-width:0;">
              <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:0.5rem;">
                {s.tags?.map((tag: string) => (
                  <span class="tag" style="font-size:0.7rem; padding:0.2rem 0.6rem;">{translateTag(tag)}</span>
                ))}
                {s.prefecture && (
                  <span style="font-size:0.7rem; padding:0.2rem 0.6rem; background:rgba(100,116,139,0.1); border-radius:999px; color:var(--text-muted); font-weight:600;">{s.prefecture}</span>
                )}
              </div>
              <h3 style="font-size:1rem; font-weight:700; color:var(--primary); margin:0 0 0.25rem; line-height:1.4;">{s.title}</h3>
              {s.use_purpose && (
                <p style="font-size:0.8rem; color:var(--text-muted); margin:0; line-height:1.5; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">{s.use_purpose}</p>
              )}
            </div>
            <div style="text-align:right; flex-shrink:0;">
              <div style="font-size:1.1rem; font-weight:800; color:var(--accent);">{formatCurrency(s.max_limit)}</div>
              {s.subsidy_rate && (
                <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.2rem;">補助率 {s.subsidy_rate}</div>
              )}
              <div style="font-size:0.75rem; color:var(--accent); margin-top:0.5rem; font-weight:600;">詳細を見る →</div>
            </div>
          </div>
        </a>
      ))}
    </div>

    {subsidies.length === 0 && (
      <div class="glass-card" style="text-align:center; padding:3rem; color:var(--text-muted);">
        <p>現在表示できる補助金情報がありません。データは毎日更新されます。</p>
      </div>
    )}

    <div class="glass-card" style="margin-top:2.5rem; text-align:center; background:linear-gradient(135deg,#0f1f3d,#1e3a6e); color:white;">
      <p style="font-size:1rem; font-weight:700; margin:0 0 0.5rem; color:white;">💴 補助金入金までの「資金ショート」対策は万全ですか？</p>
      <p style="font-size:0.85rem; color:rgba(255,255,255,0.75); margin:0 0 1.25rem;">補助金は基本的に後払い（数ヶ月〜1年後）です。入金までの立替資金として、審査の早いファクタリングが広く活用されています。</p>
      <a href={`https://px.a8.net/svt/ejp?a8mat=4B1DXN+ADAT2Q+4EKW+BX3J6&utm_source=subsidies_list&utm_medium=cta&utm_content=consult`}
         target="_blank" rel="sponsored noopener"
         style="display:inline-block; padding:0.75rem 2rem; background:white; color:#0f1f3d; border-radius:999px; font-weight:800; text-decoration:none; font-size:0.95rem;">
        最短即日で現金化（無料見積） →
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .subsidy-row-link .glass-card {
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .subsidy-row-link:hover .glass-card {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(15,31,61,0.1);
  }
</style>
