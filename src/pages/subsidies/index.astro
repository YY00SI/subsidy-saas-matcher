---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

// processedデータ読み込み
const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsidies in index.astro", e);
}

// ステータスや地域などのフィルタはMVP以降で対応
const activeSubsidies = subsidies.filter(s => s.status === '受付中' || !s.status);
---

<BaseLayout 
  title="補助金一覧" 
  description="現在受付中のIT導入・DX関連補助金の一覧です。"
>
  <div class="header-section">
    <h1>補助金一覧</h1>
    <p>{activeSubsidies.length} 件の補助金が見つかりました。</p>
  </div>

  <div class="subsidy-grid">
    {activeSubsidies.map(s => (
      <div class="card subsidy-card">
        <div class="card-header">
          <span class="area-tag">{s.target_area?.[0] || '全国'}</span>
          <span class="status-tag">受付中</span>
        </div>
        <h3><a href={`/subsidies/${s.id}`}>{s.title}</a></h3>
        <p class="summary">{s.use_purpose || s.content.substring(0, 100) + '...'}</p>
        <div class="card-footer">
          <div class="meta">
            <span class="label">上限額:</span>
            <span class="value">{s.max_limit || '要問合せ'}</span>
          </div>
          <div class="tags">
            {s.tags?.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .header-section { margin-bottom: 3rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 1rem;}
  .header-section h1 { margin-bottom: 0.5rem; }
  .header-section p { color: #64748b; }

  .subsidy-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  
  .subsidy-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .card-header { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }
  .area-tag { font-size: 0.75rem; color: #0369a1; background: #e0f2fe; padding: 0.1rem 0.5rem; border-radius: 4px; font-weight: bold; }
  .status-tag { font-size: 0.75rem; color: #15803d; background: #dcfce7; padding: 0.1rem 0.5rem; border-radius: 4px; font-weight: bold; }
  
  .subsidy-card h3 { margin: 0; font-size: 1.25rem; }
  .subsidy-card h3 a { color: #0f172a; text-decoration: none; }
  .subsidy-card h3 a:hover { color: #3b82f6; }
  
  .summary { color: #475569; font-size: 0.95rem; margin: 0.5rem 0; line-height: 1.6; }
  
  .card-footer { margin-top: auto; display: flex; justify-content: space-between; align-items: flex-end; pt: 1rem; border-top: 1px solid #f1f5f9; padding-top: 1rem;}
  .meta { display: flex; flex-direction: column; }
  .meta .label { font-size: 0.7rem; color: #94a3b8; text-transform: uppercase; }
  .meta .value { font-weight: 700; color: #0f172a; }
  
  .tags { display: flex; gap: 0.25rem; }
</style>
