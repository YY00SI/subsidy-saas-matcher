---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatCurrency } from '../../lib/normalize';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
  let subsidies = [];
  try {
    subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
  } catch (e) {
    console.warn("getStaticPaths failed in [id].astro", e);
  }
  
  return subsidies.map((s) => ({
    params: { id: s.id },
    props: { subsidy: s },
  }));
}

const { subsidy } = Astro.props;
const base = import.meta.env.BASE_URL;

// 対象補助金と相性の良いツールを読み込み
const matchesPath = path.join(process.cwd(), 'data', 'processed', 'matches.json');
const toolsPath = path.join(process.cwd(), 'data', 'tools.json');
let matchedTools = [];

try {
  const allMatches = JSON.parse(fs.readFileSync(matchesPath, 'utf8'));
  const allTools = JSON.parse(fs.readFileSync(toolsPath, 'utf8'));
  
  const relevantMatches = allMatches.filter(m => m.subsidyId === subsidy.id);
  matchedTools = relevantMatches.map(m => {
  const tool = allTools.find(t => t.slug === m.toolSlug);
  if (!tool) return null; // AIが架空のslugを出力した場合は弾く
  return { ...tool, matchScore: m.score };
  }).filter(t => t !== null)
  .sort((a, b) => (b.priority_score || 0) - (a.priority_score || 0)); // 優先スコア順にソート
} catch(e) {
  console.warn("Failed to load matching tools in [id].astro", e);
}
---

<BaseLayout 
  title={`${subsidy.title} | 補助金SaaSマッチャー`} 
  description={subsidy.use_purpose || subsidy.content?.substring(0, 100)}
>
  <nav class="breadcrumb container">
    <a href={base}>TOP</a> &gt; <a href={`${base}subsidies/`}>補助金一覧</a> &gt; <span>{subsidy.title}</span>
  </nav>

  <section class="subsidy-detail container">
    <header class="detail-header">
      <div class="header-tags">
        <span class="status-tag active">受付中</span>
        {subsidy.target_area?.map(a => <span class="tag">{a}</span>)}
      </div>
      <h1 class="page-title">{subsidy.title}</h1>
      <p class="detail-lead">{subsidy.use_purpose}</p>
    </header>

    <div class="detail-grid">
      <div class="main-content-col">
        <div class="glass-card detail-card">
          <h2 class="card-title">補助金の概要</h2>
          <div class="content-text" set:html={subsidy.content.replace(/\n/g, '<br>')} />
          
          <h3 class="card-subtitle">対象事業者</h3>
          <p class="content-text">{subsidy.target_business || '詳細は公募要領をご確認ください'}</p>
          
          {subsidy.tags && subsidy.tags.length > 0 && (
            <div class="tags-row">
              {subsidy.tags.map(t => <span class="tag tag-accent">{t}</span>)}
            </div>
          )}

          <div class="cta-box">
            <p>※必ず公式サイトで最新の公募要領をご確認の上、申請してください。</p>
            {(subsidy.detail_url || subsidy.official_url) ? (
              <a href={subsidy.detail_url || subsidy.official_url} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-large btn-block">公式サイトを確認する</a>
            ) : (
              <a href="https://www.jgrants-portal.go.jp/" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-large btn-block">JGrantsで確認する</a>
            )}
          </div>
        </div>

        {subsidy.seoArticle && (
          <div class="glass-card detail-card seo-article-card">
            <div class="seo-kicker">プロが解説する資金繰り＆活用術</div>
            <h2 class="card-title seo-title">補助金の採択率と資金繰りを最適化する</h2>
            <div class="content-text seo-content" set:html={subsidy.seoArticle} />
            
            {matchedTools.length > 0 && (
              <div class="cta-banner">
                <h3 class="cta-banner-title">この記事を読んだ方に選ばれている推奨対策サービス</h3>
                <div class="cta-banner-grid">
                  {matchedTools.slice(0, 2).map(t => (
                    <div class="matched-tool-card">
                      <div class="tool-info">
                        <div class="tool-category-badge">{t.category === 'cashflow' ? '必携の資金繰り対策' : t.category === 'corporate-card' ? '立替用法人カード' : t.category === 'consulting' ? '申請代行のプロ' : '必須バックオフィスSaaS'}</div>
                        <h4 class="tool-name">{t.name}</h4>
                        <p class="tool-strengths">{t.strengths}</p>
                      </div>
                      <a href={t.affiliate_url} target="_blank" rel="noopener noreferrer" class="cta-pulse-button">
                        公式サイトを見る・無料相談 👉
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      <aside class="sidebar-col">
        <div style="position: sticky; top: 100px; display: flex; flex-direction: column; gap: 2rem;">
          <div class="glass-card summary-card">
            <h3 class="summary-title">要項サマリー</h3>
            <ul class="summary-list">
              <li>
                <span class="l-label">上限額</span>
                <span class="l-value text-gradient">
                  {formatCurrency(subsidy.max_limit)}
                </span>
              </li>
              <li>
                <span class="l-label">補助率</span>
                <span class="l-value">{subsidy.rate || '-'}</span>
              </li>
              <li>
                <span class="l-label">対象地域</span>
                <span class="l-value">{subsidy.target_area?.join(', ') || '全国'}</span>
              </li>
            </ul>
          </div>

          <div class="tools-matching-card">
            <h2 class="sidebar-title">相性の良いツール</h2>
            {matchedTools.length > 0 ? (
              <div class="tool-list">
                {matchedTools.map(t => (
                  <div class="glass-card t-mini-card">
                    <div class="score-badge">Match: {Math.round(t.matchScore)}%</div>
                    <div class="t-cat">{t.category}</div>
                    <h4><a href={`${base}tools/${t.slug}/`}>{t.name}</a></h4>
                    <p>{t.strengths?.substring(0, 40)}...</p>
                  </div>
                ))}
              </div>
            ) : (
              <div class="glass-card empty-state" style="border-left: 4px solid var(--primary);">
                <h4 style="margin-top:0; color:var(--primary); font-size:1.05rem;">汎用おすすめツール</h4>
                <p style="font-size:0.85rem; color:var(--text-muted); margin-bottom:1rem;">どの補助金事業であっても、事業ベースとなる「会計・労務のDX」は必須です。</p>
                <a href={`${base}tools/freee-accounting/`} class="btn btn-primary btn-block" style="font-size:0.9rem; padding:0.6rem;">DX基礎ツールを見る</a>
              </div>
            )}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb { margin-bottom: 2rem; font-size: 0.85rem; color: var(--secondary); padding: 0 1.5rem;}
  .breadcrumb a { color: var(--secondary); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  .detail-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(15, 23, 42, 0.1); text-align: center;}
  .header-tags { justify-content: center; display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;}
  
  .status-tag.active { 
    background: rgba(16, 185, 129, 0.1); 
    color: var(--success); 
    padding: 0.35rem 0.85rem; 
    border-radius: 9999px; 
    font-size: 0.8rem; 
    font-weight: bold; 
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .page-title { font-size: 2.5rem; margin-bottom: 1.5rem; letter-spacing: -0.02em; }
  .detail-lead { color: var(--secondary); font-size: 1.15rem; max-width: 800px; margin: 0 auto; line-height: 1.6;}

  .detail-grid { display: grid; grid-template-columns: 1fr 360px; gap: 3rem; align-items: start;}
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }

  .detail-card { padding: 3rem 2.5rem; }
  .card-title { font-size: 1.5rem; margin-bottom: 1.5rem; padding-bottom: 0.75rem; border-bottom: 2px solid rgba(15, 23, 42, 0.1);}
  .card-subtitle { font-size: 1.25rem; margin: 2.5rem 0 1rem; color: var(--primary);}
  
  .content-text { font-size: 1.05rem; line-height: 1.8; color: var(--text-muted); }
  
  .tags-row { display: flex; gap: 0.5rem; margin: 2rem 0; flex-wrap: wrap; }
  
  /* SEO記事カード専用の装飾 */
  .seo-article-card {
    margin-top: 3rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.9) 0%, rgba(248,250,252,0.9) 100%);
  }
  .seo-kicker {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }
  .seo-title {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 1.5rem;
  }

  /* SEO記事のMarkdownレンダリング用スタイル */
  .seo-content :global(h2) {
    font-size: 1.6rem;
    color: var(--primary);
    margin: 3rem 0 1.5rem;
  }
  .seo-content :global(h3) {
    font-size: 1.25rem;
    color: var(--primary);
    margin: 2.5rem 0 1rem;
    padding-left: 1rem;
    border-left: 4px solid var(--accent);
  }
  .seo-content :global(h4) {
    font-size: 1.1rem;
    margin: 2rem 0 0.5rem;
  }
  .seo-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.9;
  }
  .seo-content :global(ul), .seo-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .seo-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .seo-content :global(strong) {
    background: linear-gradient(transparent 65%, rgba(37, 99, 235, 0.15) 65%);
    color: var(--primary);
    font-weight: 800;
  }

  /* 強烈なコンバージョンを生むCTAバナー */
  .cta-banner {
    margin-top: 4rem;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: 0 15px 35px -5px rgba(0,0,0,0.05);
  }
  .cta-banner-title {
    margin-top: 0;
    color: var(--primary);
    font-size: 1.3rem;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 1rem;
    text-align: center;
  }
  .cta-banner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .matched-tool-card {
    background: var(--bg-color);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 10px rgba(0,0,0,0.02);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-top: 4px solid var(--accent);
    transition: transform 0.3s;
  }
  .matched-tool-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 25px rgba(0,0,0,0.08);
  }
  .tool-info {
    margin-bottom: 1.5rem;
  }
  .tool-category-badge {
    font-size: 0.75rem;
    color: white;
    background: var(--primary);
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 0.8rem;
    font-weight: bold;
  }
  .tool-name {
    font-size: 1.15rem;
    color: var(--text-main);
    margin-bottom: 0.8rem;
  }
  .tool-strengths {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .cta-pulse-button {
    display: block;
    text-align: center;
    padding: 1rem;
    font-weight: 800;
    color: white;
    background: linear-gradient(135deg, var(--accent), #4F46E5);
    border-radius: 999px;
    text-decoration: none;
    font-size: 1rem;
    animation: pulse 2.5s infinite;
    transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .cta-pulse-button:hover {
    transform: translateY(-3px) scale(1.02);
    opacity: 0.95;
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4);
    color: white;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.5); }
    70% { box-shadow: 0 0 0 12px rgba(37, 99, 235, 0); }
    100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0); }
  }

  .cta-box { margin-top: 3rem; background: rgba(255, 255, 255, 0.6); padding: 2rem; border-radius: var(--radius-md); text-align: center; border: 1px dashed rgba(15, 23, 42, 0.2);}
  .cta-box p { font-size: 0.85rem; color: var(--secondary); margin-bottom: 1.5rem;}
  .btn-large { font-size: 1.1rem; padding: 1rem; }
  .btn-block { width: 100%; }

  .summary-card { padding: 2rem; }
  .summary-title { font-size: 1.1rem; margin-bottom: 1.5rem; color: var(--primary); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800;}
  .summary-list { list-style: none; padding: 0; margin: 0; }
  .summary-list li { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 0; border-bottom: 1px dashed rgba(15, 23, 42, 0.1); }
  .summary-list li:last-child { border-bottom: none; padding-bottom: 0;}
  .summary-list li:first-child { padding-top: 0;}
  
  .l-label { font-size: 0.85rem; color: var(--secondary); font-weight: 700;}
  .l-value { font-weight: 800; font-family: 'Outfit', sans-serif; font-size: 1.2rem; text-align: right;}

  .sidebar-title { font-size: 1.25rem; margin-bottom: 1.5rem; }
  .t-mini-card { padding: 1.5rem; margin-bottom: 1rem; position: relative; border-left: 4px solid var(--accent); }
  .score-badge { position: absolute; top: -10px; right: 15px; background: var(--accent); color: white; padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.7rem; font-weight: bold; box-shadow: 0 4px 10px rgba(37, 99, 235, 0.3);}
  .t-cat { font-size: 0.7rem; color: var(--secondary); text-transform: uppercase; font-weight: 800; margin-bottom: 0.5rem;}
  .t-mini-card h4 { margin: 0 0 0.5rem 0; font-size: 1.1rem; }
  .t-mini-card h4 a { color: var(--primary); text-decoration: none; }
  .t-mini-card h4 a:hover { color: var(--accent); }
  .t-mini-card p { font-size: 0.85rem; color: var(--text-muted); margin: 0; line-height: 1.5;}
  
  .empty-state { padding: 2rem; text-align: center; font-size: 0.9rem; color: var(--secondary); }
</style>
