---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

// processedデータ読み込み
const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsides in index.astro", e);
}

// 簡単な件数カウント
const activeCount = subsidies.length;
const topSubsidies = subsidies.slice(0, 3);
---

<BaseLayout 
  title="補助金SaaSマッチャー | あなたに最適なツールと補助金を見つける"
  description="会計ソフト・インボイス対応・給与計算など、自社のIT化に使える補助金を自動でマッチングするポータルサイトです。"
>
  <div class="hero">
    <h1>IT導入・経理DXを、補助金でおトクに。</h1>
    <p>今応募できる補助金と、それに最適なSaaSツールを自動マッチング。</p>
    <div class="stats">
      <span>現在 <strong>{activeCount}</strong> 件の受付中補助金を掲載しています</span>
    </div>
  </div>

  <section class="needs">
    <h2>課題・ニーズから探す</h2>
    <div class="needs-grid">
      <a href="/needs/accounting" class="need-card">会計ツールを導入したい</a>
      <a href="/needs/invoice" class="need-card">インボイス・請求書対応したい</a>
    </div>
  </section>

  <section class="latest">
    <h2>注目の補助金</h2>
    <div class="subsidy-list">
      {topSubsidies.map(s => (
        <div class="subsidy-card">
          <h3><a href={`/subsidies/${s.id}`}>{s.title}</a></h3>
          <p>{s.use_purpose || '用途設定なし'}</p>
          <div class="tags">
            {s.tags?.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
    <a href="/subsidies" class="btn-more">すべての補助金を見る →</a>
  </section>
</BaseLayout>

<style>
  .hero { text-align: center; padding: 4rem 1rem; background: #f8fafc; margin-bottom: 2rem;}
  .stats { margin-top: 2rem; color: #475569; }
  .needs-grid { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-bottom: 3rem;}
  .need-card { display: block; padding: 1.5rem 2rem; border-radius: 8px; background: #e0f2fe; color: #0369a1; text-decoration: none; font-weight: bold; border: 1px solid #bae6fd;}
  .need-card:hover { background: #bae6fd; }
  .subsidy-list { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
  .subsidy-card { padding: 1.5rem; border: 1px solid #e2e8f0; border-radius: 6px; }
  .subsidy-card h3 a { color: #0f172a; text-decoration: none; }
  .subsidy-card h3 a:hover { text-decoration: underline; }
  .tags { display: flex; gap: 0.5rem; margin-top: 1rem;}
  .tag { background: #f1f5f9; padding: 0.2rem 0.5rem; font-size: 0.8rem; border-radius: 4px;}
  .btn-more { display: inline-block; padding: 0.5rem 1rem; background: #0f172a; color: white; text-decoration: none; border-radius: 4px; }
</style>
