---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;

// processedデータ読み込み
const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsides in index.astro", e);
}

// 簡単な件数カウント
const activeCount = subsidies.length;
const topSubsidies = subsidies.slice(0, 6); // 6 items to make grid look full and premium
---

<BaseLayout 
  title="補助金SaaSマッチャー | 企業のIT化を賢くサポート"
  description="会計ソフト・インボイス対応など、自社のIT化に使える最適な補助金とSaaSツールを自動でマッチング。"
>
  <div class="homepage-wrapper">
    <!-- Hero Section -->
    <header class="hero">
      <div class="container hero-container">
        <div class="hero-content">
          <div class="badge">
            <span class="pulse-dot"></span>
            Match &amp; Grow
          </div>
          <h1 class="hero-title">IT導入・経理DXを、<br/><span class="text-gradient">補助金でもっと身近に。</span></h1>
          <p class="hero-subtitle">今すぐ応募できる補助金と、あなたの企業に最適なSaaSツールを最新AIが自動でマッチングします。</p>
          <div class="hero-actions">
            <a href={`${base}subsidies/`} class="btn btn-primary btn-large">
              補助金を探す
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="btn-icon"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#needs" class="btn btn-secondary btn-large">課題から探す</a>
          </div>
          <div class="hero-stats">
            <div class="stat-group">
              <span class="stat-label">AI自動マッチング</span>
              <span class="stat-value"><strong>{activeCount}</strong> 件の最新補助金</span>
            </div>
            <div class="stat-group">
              <span class="stat-label">専門家サポート</span>
              <span class="stat-value"><strong>即日</strong> 対応可能</span>
            </div>
          </div>
        </div>
        
        <!-- Decorative Premium UI Elements -->
        <div class="hero-decoration">
          <div class="glow-orb orb-1"></div>
          <div class="glow-orb orb-2"></div>
          <div class="glow-orb orb-3"></div>
          <div class="mock-dashboard">
            <div class="mock-header">
              <div class="dots"><i/><i/><i/></div>
              <div class="mock-title">SaaS Matching Engine AI</div>
            </div>
            <div class="mock-body">
              <div class="mock-item anim-item-1">
                <div class="m-icon" style="background: linear-gradient(135deg, #10B981, #059669)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                </div>
                <div class="m-lines"><div class="ml-1"/><div class="ml-2"/></div>
                <div class="m-badge" style="color:#059669; background:rgba(16,185,129,0.1)">Match: 99%</div>
              </div>
              <div class="mock-item anim-item-2">
                <div class="m-icon" style="background: linear-gradient(135deg, #2563EB, #1D4ED8)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                </div>
                <div class="m-lines"><div class="ml-1" style="width:60%"/><div class="ml-2" style="width:40%"/></div>
                <div class="m-badge" style="color:#1D4ED8; background:rgba(37,99,235,0.1)">資金対策</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="container">
      <section id="needs" class="needs-section">
        <div class="section-header">
          <h2 class="section-title">カテゴリーから探す</h2>
          <p class="section-desc">解決したい業務ツールに合わせて最適な補助金を見つけましょう。</p>
        </div>
        <div class="needs-grid">
          <a href={`${base}tools/freee-accounting/`} class="glass-card need-card problem-card">
            <div class="problem-header text-gradient">課題 01</div>
            <div class="need-icon-wrapper">
              <span class="need-icon">💶</span>
            </div>
            <h3>「毎月の経理・請求書発行が辛い…」</h3>
            <p>紙やエクセルの管理から脱却し、クラウド会計で劇的に自動化。インボイスや電帳法にも完全対応。</p>
            <div class="need-action">
              <span class="suggest-tag">おすすめ: 会計DXツール</span>
              <div class="need-arrow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
            </div>
          </a>
          <a href={`${base}needs/invoice/`} class="glass-card need-card problem-card">
            <div class="problem-header text-gradient">課題 02</div>
            <div class="need-icon-wrapper">
              <span class="need-icon">💳</span>
            </div>
            <h3>「立替払いや資金繰りが厳しい…」</h3>
            <p>補助金特有の手元資金ショートを防ぐ、最新の法改正対応ファクタリングや法人カードの活用法。</p>
            <div class="need-action">
              <span class="suggest-tag">関連補助金をチェック</span>
              <div class="need-arrow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
            </div>
          </a>
        </div>
      </section>

      <section class="latest-section">
        <div class="section-header">
          <h2 class="section-title">注目の最新補助金</h2>
          <a href={`${base}subsidies/`} class="view-all">すべて見る →</a>
        </div>
        
        <div class="subsidy-grid">
          {topSubsidies.map(s => (
            <div class="glass-card subsidy-card">
              <div class="s-card-header">
                <span class="tag">{s.target_area?.[0] || '全国'}</span>
                {s.tags?.slice(0, 1).map(t => <span class="tag tag-accent">{t}</span>)}
              </div>
              <h3 class="s-card-title"><a href={`${base}subsidies/${s.id}/`}>{s.title}</a></h3>
              <p class="s-card-desc">{s.use_purpose || '用途設定なし'}</p>
              
              <div class="s-card-footer">
                <div class="s-card-meta">
                  <span class="meta-label">上限額</span>
                  <span class="meta-value text-gradient">{s.max_limit || '要問合せ'}</span>
                </div>
                <a href={`${base}subsidies/${s.id}/`} class="detail-link">詳細へ →</a>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  /* Base layout adjustments */
  .homepage-wrapper {
    margin-top: -2rem; /* Pull up into the header slightly */
  }

  /* Premium Hero Section */
  .hero {
    position: relative;
    padding: 6rem 0 5rem;
    display: flex;
    justify-content: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    overflow: hidden;
  }
  
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at center, rgba(255,255,255,0.7) 0%, rgba(248,250,252,0) 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    text-align: left;
    max-width: 650px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    color: var(--accent);
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 1);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background-color: var(--success);
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    animation: pulse-dot 2s infinite cubic-bezier(0.66, 0, 0, 1);
  }

  @keyframes pulse-dot {
    to {
      box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
    }
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
    color: var(--primary);
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--secondary);
    margin: 0 0 3rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .btn-icon {
    margin-left: 0.5rem;
    transition: transform 0.3s;
  }

  .btn-primary:hover .btn-icon {
    transform: translateX(4px);
  }

  .hero-stats {
    display: flex;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
  }

  .stat-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .stat-value {
    color: var(--primary);
    font-size: 1rem;
  }

  .stat-value strong {
    color: var(--accent);
    font-size: 1.3rem;
    font-family: 'Outfit', sans-serif;
  }

  /* High-end Dashboard Mockup */
  .hero-decoration {
    position: relative;
    width: 100%;
    height: 500px;
    perspective: 1000px;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.6;
    z-index: 0;
  }

  .orb-1 {
    top: 10%; right: 10%;
    width: 250px; height: 250px;
    background: var(--accent);
    animation: drift 10s ease-in-out infinite alternate;
  }

  .orb-2 {
    bottom: 10%; left: 10%;
    width: 300px; height: 300px;
    background: #ec4899;
    animation: drift 15s ease-in-out infinite alternate-reverse;
  }

  .orb-3 {
    top: 40%; left: 40%;
    width: 200px; height: 200px;
    background: #10b981;
    animation: drift 12s ease-in-out infinite alternate;
  }

  @keyframes drift {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(30px, -30px) scale(1.1); }
  }

  .mock-dashboard {
    position: absolute;
    top: 50%; right: 0;
    width: 110%;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 24px;
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.1), inset 0 1px 1px rgba(255,255,255,1);
    transform: translateY(-50%) rotateY(-10deg) rotateX(5deg);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    animation: floating-dash 8s ease-in-out infinite;
    z-index: 10;
  }

  @keyframes floating-dash {
    0%, 100% { transform: translateY(-50%) rotateY(-10deg) rotateX(5deg); }
    50% { transform: translateY(-55%) rotateY(-8deg) rotateX(6deg); }
  }

  .mock-header {
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    display: flex; align-items: center; gap: 1rem;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 24px 24px 0 0;
  }

  .dots { display: flex; gap: 8px; }
  .dots i { width: 12px; height: 12px; border-radius: 50%; display: block; }
  .dots i:nth-child(1) { background: #ef4444; }
  .dots i:nth-child(2) { background: #f59e0b; }
  .dots i:nth-child(3) { background: #10b981; }

  .mock-title { font-size: 0.75rem; font-weight: 800; color: #64748b; letter-spacing: 0.15em; text-transform: uppercase;}
  
  .mock-body { padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }

  .mock-item { 
    display: flex; align-items: center; gap: 1rem; padding: 1.25rem; 
    background: white; border-radius: 16px; 
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.05);
  }

  .anim-item-1 { animation: slide-in 0.6s ease-out backwards 0.5s; }
  .anim-item-2 { animation: slide-in 0.6s ease-out backwards 0.7s; }

  @keyframes slide-in {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .m-icon { width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0; display:flex; align-items:center; justify-content:center; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  .m-lines { flex: 1; display: flex; flex-direction: column; gap: 10px;}
  .ml-1 { height: 8px; width: 85%; background: var(--secondary); border-radius: 4px; opacity: 0.2; }
  .ml-2 { height: 8px; width: 40%; background: var(--secondary); border-radius: 4px; opacity: 0.1; }
  .m-badge { 
    padding: 0.5rem 1rem; font-size: 0.8rem; font-weight: 800; border-radius: 999px;
  }

  /* Sections */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
  }

  .section-desc {
    color: var(--secondary);
    font-size: 1.1rem;
    margin: 0;
  }

  .view-all {
    font-weight: 700;
    text-decoration: none;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .view-all:hover {
    gap: 0.8rem;
  }

  /* Needs Grid */
  .needs-section {
    padding: 8rem 0;
  }

  .needs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2.5rem;
  }

  .need-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    padding: 3rem;
  }

  .need-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 5px;
    background: linear-gradient(90deg, var(--accent) 0%, #8b5cf6 100%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .need-card:hover::before {
    opacity: 1;
  }

  .need-icon-wrapper {
    width: 60px; height: 60px;
    background: rgba(37,99,235,0.1);
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.5rem;
  }

  .need-icon { font-size: 2rem; }

  .need-card h3 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .need-card p {
    color: var(--secondary);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    flex: 1;
  }

  .problem-header {
    font-size: 0.95rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  
  .need-action {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
    padding-top: 1.5rem;
  }

  .suggest-tag {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    background: rgba(37, 99, 235, 0.1);
    padding: 0.4rem 1rem;
    border-radius: 999px;
  }

  .need-arrow {
    width: 44px; height: 44px; border-radius: 50%;
    background: white; color: var(--accent);
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    display: flex; align-items: center; justify-content: center;
    font-weight: bold; transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .need-card:hover .need-arrow {
    background: var(--accent);
    color: white;
    transform: translateX(5px) rotate(45deg);
  }

  /* Latest Subsidies */
  .latest-section {
    padding-bottom: 8rem;
  }

  .subsidy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2.5rem;
  }

  .subsidy-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
  }

  .s-card-header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .s-card-title {
    font-size: 1.4rem;
    margin-bottom: 1.25rem;
  }

  .s-card-title a {
    color: var(--primary);
    text-decoration: none;
  }

  .s-card-title a:hover {
    color: var(--accent);
  }

  .s-card-desc {
    color: var(--secondary);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    flex: 1;
  }

  .s-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
    padding-top: 1.5rem;
  }

  .meta-label {
    font-size: 0.8rem;
    color: var(--secondary);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .meta-value {
    font-size: 1.4rem;
    margin-top: 0.25rem;
  }

  .detail-link {
    font-size: 1rem;
    font-weight: 700;
    display: flex; align-items: center; gap: 0.25rem;
  }

  .detail-link:hover {
    text-decoration: none;
    transform: translateX(4px);
  }

  @media (max-width: 1024px) {
    .hero-container { grid-template-columns: 1fr; }
    .hero-decoration { display: none; }
    .hero-content { margin: 0 auto; text-align: center; }
    .hero-actions { justify-content: center; }
    .hero-stats { justify-content: center; }
  }
</style>
