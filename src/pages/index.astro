---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatCurrency } from '../lib/normalize';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;

const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsidies", e);
}

const activeCount = subsidies.length;

// 安全なソートロジック（日本語キーワードを含まない）
const sortedSubsidies = subsidies.sort((a, b) => {
  const getScore = (s) => (s.tags?.includes('accounting') ? 1 : 0);
  return getScore(b) - getScore(a);
});

const topSubsidies = sortedSubsidies.slice(0, 6); 
---
<BaseLayout title="補助金SaaSマッチャー | 企業のIT化を賢くサポート">
  <div class="homepage-wrapper">
    <header class="hero">
      <div class="container hero-container">
        <div class="hero-content">
          <h1>IT導入・補助金をもっと身近に。</h1>
          <p>今すぐ応募できる補助金と、最適なSaaSツールをAIが自動でマッチングします。</p>
          <div class="hero-actions">
            <a href={`${base}diagnose/`} class="btn btn-accent btn-large">無料SaaS診断</a>
            <a href={`${base}subsidies/`} class="btn btn-primary btn-large">補助金を探す</a>
          </div>
        </div>
      </div>
    </header>
  </div>
</BaseLayout>
