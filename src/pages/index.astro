---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatCurrency } from '../lib/normalize';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;

const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsidies", e);
}

const activeCount = subsidies.length;

// 安全なソートロジック（日本語キーワードを含まない）
const sortedSubsidies = subsidies.sort((a, b) => {
  const getScore = (s) => (s.tags?.includes('accounting') ? 1 : 0);
  return getScore(b) - getScore(a);
});

const topSubsidies = sortedSubsidies.slice(0, 6); 
---
<BaseLayout title="補助金SaaSマッチャー | 企業のIT化を賢くサポート">
  <div style="background:linear-gradient(135deg, #0f1f3d 0%, #1e3a6e 100%); padding:4rem 1.5rem; text-align:center; color:white; overflow:hidden;">
    <div class="container" style="max-width:860px; margin:0 auto; position:relative; z-index:1;">
      <div style="display:inline-flex; align-items:center; gap:0.4rem; background:rgba(255,255,255,0.12); color:#93c5fd; border:1px solid rgba(147,197,253,0.3); padding:0.4rem 1rem; border-radius:999px; font-size:0.8rem; font-weight:600; margin-bottom:1.5rem;">
        ✦ あなたにピッタリの支援が見つかる
      </div>
      <h1 style="font-size:2.2rem; font-weight:800; line-height:1.3; margin:0 0 1rem; color:white;">IT導入・補助金をもっと身近に。</h1>
      <p style="color:rgba(255,255,255,0.8); font-size:0.95rem; line-height:1.7; max-width:480px; margin:0 auto 2rem;">今すぐ応募できる補助金と、最適なSaaSツールをAIが自動でマッチングします。</p>
      
      <div style="display:flex; flex-direction:column; gap:1rem; align-items:center;">
        <a href={`${base}diagnose/`} style="display:inline-block; padding:1rem 2rem; background:#2563eb; color:white; border-radius:12px; font-weight:700; text-decoration:none; font-size:1.1rem; box-shadow:0 8px 24px rgba(37,99,235,0.3); transition:transform 0.2s;">🔍 1分でわかる！無料SaaS診断</a>
        <a href={`${base}subsidies/`} style="display:inline-block; color:white; font-size:0.9rem; text-decoration:underline; font-weight:600; opacity:0.8;">まずは一覧から補助金を探す →</a>
      </div>
    </div>
  </div>

  <section style="padding:4rem 1.5rem; background:#f8fafc;">
    <div class="container" style="max-width:860px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:2.5rem;">
        <h2 style="font-size:1.5rem; font-weight:800; color:#0f1f3d; margin:0 0 0.5rem;">🏢 業種別のおすすめツール活用事例</h2>
        <p style="color:#64748b; font-size:0.95rem; margin:0;">各業界で定番となっている補助金×ツールの成功事例</p>
      </div>
      
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:1.5rem;">
        <div class="glass-card" style="padding:1.5rem; background:white; border-radius:12px; border:1px solid #e2e8f0; box-shadow:0 4px 16px rgba(15,31,61,0.05);">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0f1f3d; margin:0 0 1rem;">🛒 フリーランス・個人事業主</h3>
          <p style="font-weight:700; font-size:0.95rem; color:#2563eb; margin:0 0 0.5rem;">小規模持続化補助金 × 請求業務DX</p>
          <p style="font-size:0.85rem; color:#64748b; line-height:1.6; margin:0 0 1rem;">インボイス対応の請求書ソフト導入費用を補助金で補填。毎月の手作業をなくす王道パターンです。</p>
          <a href={`${base}cases/freelance-invoice-dx/`} style="display:inline-block; font-size:0.85rem; font-weight:700; color:var(--accent); text-decoration:none; border-bottom:1px solid var(--accent);">事例の詳細を読む →</a>
        </div>
        <div class="glass-card" style="padding:1.5rem; background:white; border-radius:12px; border:1px solid #e2e8f0; box-shadow:0 4px 16px rgba(15,31,61,0.05);">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0f1f3d; margin:0 0 1rem;">🏗️ 建設・製造・運輸業</h3>
          <p style="font-weight:700; font-size:0.95rem; color:#2563eb; margin:0 0 0.5rem;">IT導入補助金 × クラウドERP</p>
          <p style="font-size:0.85rem; color:#64748b; line-height:1.6; margin:0 0 1rem;">複雑な原価計算や給与・勤怠を一つのプラットフォームで一元管理し、業務の属人化を防ぎます。</p>
          <a href={`${base}cases/construction-erp-dx/`} style="display:inline-block; font-size:0.85rem; font-weight:700; color:var(--accent); text-decoration:none; border-bottom:1px solid var(--accent);">事例の詳細を読む →</a>
        </div>
        <div class="glass-card" style="padding:1.5rem; background:white; border-radius:12px; border:1px solid #e2e8f0; box-shadow:0 4px 16px rgba(15,31,61,0.05);">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0f1f3d; margin:0 0 1rem;">🏢 サービス・IT企業</h3>
          <p style="font-weight:700; font-size:0.95rem; color:#2563eb; margin:0 0 0.5rem;">小規模持続化補助金 × 会計ソフト</p>
          <p style="font-size:0.85rem; color:#64748b; line-height:1.6; margin:0 0 1rem;">日々の記帳作業をAI推測と口座同期により激減させ、本業の商談やクリエイティブに集中します。</p>
          <a href={`${base}cases/service-accounting-dx/`} style="display:inline-block; font-size:0.85rem; font-weight:700; color:var(--accent); text-decoration:none; border-bottom:1px solid var(--accent);">事例の詳細を読む →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
