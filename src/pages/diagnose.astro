---
import fs from 'fs';
import path from 'path';

const toolsPath = path.join(process.cwd(), 'data', 'tools.json');
const tools = JSON.parse(fs.readFileSync(toolsPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>辟｡譁呵ｨｺ譁ｭ 笏 縺ゅ↑縺溘↓譛驕ｩ縺ｪSaaS縺ｨ陬懷勧驥代ｒ險ｺ譁ｭ | 陬懷勧驥全aaS繝槭ャ繝√Ε繝ｼ</title>
  <meta name="description" content="讌ｭ遞ｮ繝ｻ蠕捺･ｭ蜩｡謨ｰ繝ｻ縺雁峅繧翫＃縺ｨ繧帝∈縺ｶ縺縺代・I縺梧怙驕ｩ縺ｪ莨夊ｨ医・邨瑚ｲｻSaaS縺ｨ菴ｿ縺医ｋ陬懷勧驥代ｒ辟｡譁吶〒縺疲署譯医＠縺ｾ縺吶・ />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <style>
    :root { --navy: #0f1f3d; --indigo: #1e3a6e; --accent: #2563eb; --accent-light: #dbeafe; --green: #059669; --green-light: #d1fae5; --text: #1e293b; --muted: #64748b; --border: #e2e8f0; --bg: #f8fafc; --white: #ffffff; --radius: 12px; --shadow: 0 4px 24px rgba(15,31,61,0.08); }
    body { font-family: 'Noto Sans JP', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; margin: 0; padding: 0; }
    .site-header { background: var(--navy); padding: 14px 24px; display: flex; align-items: center; gap: 8px; }
    .site-header a { color: #fff; text-decoration: none; font-size: 15px; font-weight: 500; opacity: 0.85; }
    .hero { background: linear-gradient(135deg, var(--navy) 0%, var(--indigo) 100%); padding: 48px 24px; text-align: center; color: white; }
    .hero h1 { font-family: 'DM Serif Display', serif; font-size: 28px; margin-bottom: 8px; }
    .hero p { opacity: 0.8; font-size: 14px; }
    
    main { max-width: 680px; margin: 0 auto; padding: 32px 20px 80px; }
    .card { background: var(--white); border-radius: 16px; box-shadow: var(--shadow); padding: 32px; min-height: 480px; display: flex; flex-direction: column; }
    
    .step-title { font-size: 20px; font-weight: 700; margin-bottom: 24px; color: var(--navy); }
    .options-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 24px; }
    .option-btn { padding: 16px; border: 2px solid var(--border); border-radius: var(--radius); cursor: pointer; text-align: left; background: white; transition: all 0.2s; outline: none; }
    .option-btn:hover { border-color: var(--accent); }
    .option-btn.selected { border-color: var(--accent); background: var(--accent-light); }
    .option-icon { font-size: 24px; margin-bottom: 8px; display: block; }
    .option-label { font-weight: 700; font-size: 15px; display: block; margin-bottom: 4px; }
    .option-desc { font-size: 12px; color: var(--muted); }

    .nav-row { margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 24px; }
    .btn-next { padding: 12px 32px; background: var(--accent); border: none; border-radius: 8px; color: white; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-next:hover:not(:disabled) { background: #1d4ed8; }
    .btn-next:disabled { background: #cbd5e1; cursor: not-allowed; }
    .btn-back { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 14px; }

    [data-step] { display: none; }
    [data-step].active { display: flex; flex-direction: column; height: 100%; }

    .result-card { text-align: center; }
    .result-header { margin-bottom: 24px; }
    .result-badge { background: var(--green-light); color: var(--green); padding: 4px 12px; border-radius: 99px; font-weight: 800; font-size: 12px; margin-bottom: 12px; display: inline-block; }
    .tool-result-box { background: #f1f5f9; padding: 24px; border-radius: 12px; margin-bottom: 24px; text-align: left; border-left: 4px solid var(--accent); }
    .tool-name { font-size: 20px; font-weight: 800; color: var(--navy); margin-bottom: 8px; display: block; }
    .tool-desc { font-size: 14px; color: var(--text); line-height: 1.6; }
    .cta-button { display: block; width: 100%; padding: 16px; background: var(--accent); color: white; text-decoration: none; border-radius: 8px; font-weight: 800; margin-top: 16px; text-align: center; }
    .subsidy-link { color: var(--accent); font-weight: 700; text-decoration: underline; margin-top: 16px; display: inline-block; }

    .progress-wrap { display: flex; justify-content: center; gap: 8px; margin-bottom: 20px; }
    .p-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.3); }
    .p-dot.active { background: white; width: 24px; border-radius: 5px; }

    .loading-spinner { border: 4px solid #f3f3f3; border-top: 4px solid var(--accent); border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 20px auto; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <header class="site-header">
    <a href={`${base}`}>笨ｨ 陬懷勧驥全aaS繝槭ャ繝√Ε繝ｼ</a>
  </header>
  <div class="hero">
    <div class="progress-wrap">
      <div class="p-dot active" data-p="1"></div>
      <div class="p-dot" data-p="2"></div>
      <div class="p-dot" data-p="3"></div>
      <div class="p-dot" data-p="4"></div>
    </div>
    <h1>譛驕ｩ縺ｪSaaS縺ｨ陬懷勧驥代ｒ險ｺ譁ｭ</h1>
    <p>縺・￥縺､縺九・雉ｪ蝠上↓遲斐∴繧九□縺代〒縲、I縺梧怙驕ｩ縺ｪ邨・∩蜷医ｏ縺帙ｒ蛻､螳壹＠縺ｾ縺吶・/p>
  </div>
  
  <main>
    <div class="card" id="wizard-card">
      <!-- Step 1: 讌ｭ遞ｮ -->
      <div data-step="1" class="active">
        <h2 class="step-title">Q1. 縺ゅ↑縺溘・讌ｭ遞ｮ縺ｯ・・/h2>
        <div class="options-grid">
          <button class="option-btn" data-type="industry" data-value="retail">
            <span class="option-icon">將</span>
            <span class="option-label">鬟ｲ鬟溘・蟆丞｣ｲ繝ｻ繧ｵ繝ｼ繝薙せ</span>
            <span class="option-desc">蠎苓・驕句霧繧・磁螳｢縺御ｸｭ蠢・/span>
          </button>
          <button class="option-btn" data-type="industry" data-value="construction">
            <span class="option-icon">女・・/span>
            <span class="option-label">蟒ｺ險ｭ繝ｻ荳榊虚逕｣繝ｻ陬ｽ騾</span>
            <span class="option-desc">迴ｾ蝣ｴ菴懈･ｭ繧・惠蠎ｫ邂｡逅・′縺ゅｋ</span>
          </button>
          <button class="option-btn" data-type="industry" data-value="office">
            <span class="option-icon">捗</span>
            <span class="option-label">IT繝ｻ蟆る摩閨ｷ繝ｻ繧ｪ繝輔ぅ繧ｹ</span>
            <span class="option-desc">繝・せ繧ｯ繝ｯ繝ｼ繧ｯ荳ｭ蠢・/span>
          </button>
          <button class="option-btn" data-type="industry" data-value="other">
            <span class="option-icon">召</span>
            <span class="option-label">縺昴・莉・/span>
            <span class="option-desc">荳願ｨ倅ｻ･螟悶・讌ｭ遞ｮ</span>
          </button>
        </div>
        <div class="nav-row">
          <span></span>
          <button class="btn-next" data-next-from="1" disabled>谺｡縺ｸ騾ｲ繧</button>
        </div>
      </div>

      <!-- Step 2: 隱ｲ鬘・-->
      <div data-step="2">
        <h2 class="step-title">Q2. 莉翫∬ｧ｣豎ｺ縺励◆縺・ｪｲ鬘後・・・/h2>
        <div class="options-grid">
          <button class="option-btn" data-type="need" data-value="accounting">
            <span class="option-icon">投</span>
            <span class="option-label">邨檎炊繝ｻ遒ｺ螳夂筏蜻翫・蜉ｹ邇・喧</span>
            <span class="option-desc">繧､繝ｳ繝懊う繧ｹ繧・崕蟶ｳ豕募ｯｾ蠢・/span>
          </button>
          <button class="option-btn" data-type="need" data-value="invoice">
            <span class="option-icon">ｧｾ</span>
            <span class="option-label">隲区ｱよ嶌逋ｺ陦後・蜿怜叙</span>
            <span class="option-desc">繝溘せ縺ｮ蜑頑ｸ帙√・繝ｼ繝代・繝ｬ繧ｹ</span>
          </button>
          <button class="option-btn" data-type="need" data-value="cashflow">
            <span class="option-icon">腸</span>
            <span class="option-label">雉・≡郢ｰ繧翫・遶区崛蟇ｾ遲・/span>
            <span class="option-desc">謇句・雉・≡縺ｮ荳榊ｮ峨ｒ隗｣豸・/span>
          </button>
          <button class="option-btn" data-type="need" data-value="cost">
            <span class="option-icon">悼</span>
            <span class="option-label">騾壻ｿ｡雋ｻ繧・崋螳夊ｲｻ縺ｮ蜑頑ｸ・/span>
            <span class="option-desc">譛医・・謾ｯ謇輔＞繧呈椛縺医◆縺・/span>
          </button>
        </div>
        <div class="nav-row">
          <button class="btn-back" data-back-to="1">謌ｻ繧・/button>
          <button class="btn-next" data-next-from="2" disabled>谺｡縺ｸ騾ｲ繧</button>
        </div>
      </div>

      <!-- Step 3: 隕乗ｨ｡ -->
      <div data-step="3">
        <h2 class="step-title">Q3. 蠕捺･ｭ蜩｡謨ｰ縺ｯ菴募錐縺ｧ縺吶°・・/h2>
        <div class="options-grid">
          <button class="option-btn" data-type="size" data-value="solo">
            <span class="option-icon">側</span>
            <span class="option-label">1縲・蜷・/span>
            <span class="option-desc">蛟倶ｺｺ莠区･ｭ荳ｻ繝ｻ蟆剰ｦ乗ｨ｡</span>
          </button>
          <button class="option-btn" data-type="size" data-value="medium">
            <span class="option-icon">則</span>
            <span class="option-label">6縲・0蜷・/span>
            <span class="option-desc">荳ｭ蟆剰ｦ乗ｨ｡莠区･ｭ閠・/span>
          </button>
          <button class="option-btn" data-type="size" data-value="large">
            <span class="option-icon">小</span>
            <span class="option-label">21蜷堺ｻ･荳・/span>
            <span class="option-desc">荳ｭ蝣・ｻ･荳翫・隕乗ｨ｡</span>
          </button>
        </div>
        <div class="nav-row">
          <button class="btn-back" data-back-to="2">謌ｻ繧・/button>
          <button class="btn-next" data-next-from="3" id="final-submit" disabled>險ｺ譁ｭ邨先棡繧定ｦ九ｋ</button>
        </div>
      </div>

      <!-- Step 4: 邨先棡 -->
      <div data-step="4" class="result-card" id="result-step">
        <div class="result-header">
          <div class="result-badge">險ｺ譁ｭ螳御ｺ・/div>
          <h2 class="step-title">縺ゅ↑縺溘↓譛驕ｩ縺ｪ讒区・縺瑚ｦ九▽縺九ｊ縺ｾ縺励◆</h2>
        </div>
        
        <div id="result-container">
          <div class="loading-spinner"></div>
          <p>繝槭ャ繝√Φ繧ｰ繧定ｨ育ｮ嶺ｸｭ...</p>
        </div>

        <div class="nav-row" style="justify-content: center; margin-top: 32px;">
          <a href={`${base}subsidies/`} class="subsidy-link">莉悶・陬懷勧驥代ｂ荳隕ｧ縺ｧ隕九ｋ</a>
        </div>
      </div>
    </div>
  </main>

  <script is:inline define:vars={{ tools, base }}>
    // Astro縺ｮ繝薙Ν繝牙ｾ後ｂ遒ｺ螳溘↓蜍輔￥繧医≧縺ｫ讓呎ｺ褒S縺ｧ險倩ｿｰ
    (function() {
      let currentStep = 1;
      const selections = {
        industry: null,
        need: null,
        size: null
      };

      // 繝壹・繧ｸ隱ｭ縺ｿ霎ｼ縺ｿ螳御ｺ・ｒ蠕・▽
      function init() {
        const optionBtns = document.querySelectorAll('.option-btn');
        const nextBtns = document.querySelectorAll('.btn-next');
        const backBtns = document.querySelectorAll('.btn-back');

        optionBtns.forEach(btn => {
          btn.addEventListener('click', function() {
            const type = this.getAttribute('data-type');
            const val = this.getAttribute('data-value');
            const stepDiv = this.closest('[data-step]');
            
            stepDiv.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
            this.classList.add('selected');
            
            selections[type] = val;
            stepDiv.querySelector('.btn-next').disabled = false;
          });
        });

        nextBtns.forEach(btn => {
          btn.addEventListener('click', function() {
            const fromStep = parseInt(this.getAttribute('data-next-from'));
            if (fromStep === 3) {
              calculateResult();
            }
            changeStep(fromStep + 1);
          });
        });

        backBtns.forEach(btn => {
          btn.addEventListener('click', function() {
            const toStep = parseInt(this.getAttribute('data-back-to'));
            changeStep(toStep);
          });
        });
      }

      function changeStep(n) {
        const steps = document.querySelectorAll('[data-step]');
        const pDots = document.querySelectorAll('.p-dot');
        
        steps.forEach(s => s.classList.remove('active'));
        pDots.forEach(d => d.classList.remove('active'));
        
        const nextTarget = document.querySelector(`[data-step="${n}"]`);
        const dotTarget = document.querySelector(`[data-p="${n}"]`);
        
        if (nextTarget) nextTarget.classList.add('active');
        if (dotTarget) dotTarget.classList.add('active');
        
        currentStep = n;
        window.scrollTo(0, 0);
      }

      function calculateResult() {
        const container = document.getElementById('result-container');
        let tool = null;
        let subsidyName = "IT蟆主・陬懷勧驥托ｼ医う繝ｳ繝懊う繧ｹ譫繝ｻ騾壼ｸｸ譫・・;
        let message = "";

        if (selections.need === 'accounting') {
          tool = tools.find(t => t.slug === 'freee-accounting');
          message = "縲先ｳ墓隼豁｣蟇ｾ蠢懊醍ｵ檎炊縺ｮ閾ｪ蜍募喧縺ｨ陬懷勧驥醍筏隲九ｒ繧ｻ繝・ヨ縺ｧ陦後≧縺ｮ縺梧怙繧ょ柑邇・噪縺ｧ縺吶・;
        } else if (selections.need === 'invoice') {
          tool = tools.find(t => t.slug === 'kanbei-sign');
          message = "縲舌さ繧ｹ繝亥炎貂帙大･醍ｴ・嶌繧・ｫ区ｱよ嶌縺ｮ繝・ず繧ｿ繝ｫ蛹悶↓繧医ｊ縲∝魂邏吩ｻ｣繧・Ψ騾∬ｲｻ繧貞炎貂帙＠縺ｾ縺励ｇ縺・・;
        } else if (selections.need === 'cashflow') {
          tool = tools.find(t => t.slug === 'recruit-tatemae');
          subsidyName = "雉・≡郢ｰ繧頑隼蝟・し繝昴・繝・/ 蜷・ｨｮ陬懷勧驥・;
          message = "縲千ｫ区崛雉・≡蟇ｾ遲悶題｣懷勧驥大・驥代∪縺ｧ縺ｮ繧ｭ繝｣繝・す繝･繝輔Ο繝ｼ繧堤乢遏ｳ縺ｫ縺吶ｋ縺溘ａ縺ｮ謗ｨ螂ｨ讒区・縺ｧ縺吶・;
        } else {
          tool = tools.find(t => t.slug === 'cloudphone');
          message = "縲仙崋螳夊ｲｻ蜑頑ｸ帙代ユ繝ｬ繝ｯ繝ｼ繧ｯ縺ｫ繧ょｯｾ蠢懊＠縺滓ｬ｡荳紋ｻ｣縺ｮ髮ｻ隧ｱ迺ｰ蠅・ｒ縲∬｣懷勧驥代ｒ豢ｻ逕ｨ縺励※讒狗ｯ峨＠縺ｾ縺励ｇ縺・・;
        }

        if (tool) {
          setTimeout(() => {
            container.innerHTML = `
              <div class="tool-result-box">
                <div style="color:var(--accent); font-weight:800; font-size:12px; margin-bottom:8px;">謗ｨ螂ｨ繝・・繝ｫ</div>
                <span class="tool-name">${tool.name}</span>
                <p class="tool-desc">${tool.strengths}</p>
                <p style="font-size:13px; color:var(--muted); margin-top:12px;">庁 <strong>險ｺ譁ｭ繧｢繝峨ヰ繧､繧ｹ:</strong> ${message}</p>
                <a href="${tool.affiliate_url}" target="_blank" rel="sponsored noopener" class="cta-button">
                  陬懷勧驥代・繝ｩ繝ｳ縺ｮ隧ｳ邏ｰ繧定ｦ九ｋ 痩
                </a>
              </div>
              <div class="tool-result-box" style="border-left-color: var(--green);">
                <div style="color:var(--green); font-weight:800; font-size:12px; margin-bottom:8px;">豢ｻ逕ｨ縺ｧ縺阪ｋ陬懷勧驥・/div>
                <span class="tool-name" style="font-size:18px;">${subsidyName}</span>
                <p class="tool-desc">縺ゅ↑縺溘・讌ｭ遞ｮ縺ｨ隕乗ｨ｡縺ｧ縺ゅｌ縺ｰ縲∝ｰ主・雋ｻ逕ｨ縺ｮ譛螟ｧ3/4縺瑚｣懷勧縺輔ｌ繧句庄閭ｽ諤ｧ縺後≠繧翫∪縺吶・/p>
              </div>
            `;
          }, 800);
        }
      }

      // 螳溯｡・
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</body>
</html>
