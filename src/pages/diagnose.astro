---
// src/pages/diagnose.astro
// 補助金SaaSマッチャー 診断ウィザード
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>無料診断 ─ あなたに最適なSaaSと補助金を診断 | 補助金SaaSマッチャー</title>
  <meta name="description" content="業種・従業員数・お困りごとを選ぶだけ。AIが最適な会計・経費SaaSと使える補助金を無料でご提案します。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <style>
    :root {
      --navy: #0f1f3d;
      --indigo: #1e3a6e;
      --accent: #2563eb;
      --accent-light: #dbeafe;
      --green: #059669;
      --green-light: #d1fae5;
      --text: #1e293b;
      --muted: #64748b;
      --border: #e2e8f0;
      --bg: #f8fafc;
      --white: #ffffff;
      --radius: 12px;
      --shadow: 0 4px 24px rgba(15,31,61,0.08);
      --shadow-lg: 0 8px 40px rgba(15,31,61,0.14);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ─── Header ─── */
    .site-header {
      background: var(--navy);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .site-header a {
      color: #fff;
      text-decoration: none;
      font-size: 15px;
      font-weight: 500;
      opacity: 0.85;
    }
    .site-header a:hover { opacity: 1; }
    .site-header span { color: rgba(255,255,255,0.4); font-size: 13px; }

    /* ─── Hero ─── */
    .hero {
      background: linear-gradient(135deg, var(--navy) 0%, var(--indigo) 100%);
      padding: 56px 24px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(37,99,235,0.18) 0%, transparent 70%);
      top: -200px; right: -100px;
      border-radius: 50%;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.12);
      color: #93c5fd;
      border: 1px solid rgba(147,197,253,0.3);
      padding: 5px 14px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 500;
      margin-bottom: 20px;
      letter-spacing: 0.02em;
    }
    .hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(24px, 4vw, 36px);
      color: #fff;
      line-height: 1.3;
      margin-bottom: 14px;
    }
    .hero h1 em {
      font-style: normal;
      color: #93c5fd;
    }
    .hero p {
      color: rgba(255,255,255,0.72);
      font-size: 15px;
      line-height: 1.7;
      max-width: 480px;
      margin: 0 auto;
    }

    /* ─── Progress ─── */
    .progress-wrap {
      max-width: 600px;
      margin: 32px auto 0;
      padding: 0 24px;
      position: relative;
      z-index: 1;
    }
    .progress-steps {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
    }
    .step-dot {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      border: 2px solid rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5);
      transition: all 0.3s ease;
      flex-shrink: 0;
    }
    .step-dot.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      box-shadow: 0 0 0 4px rgba(37,99,235,0.3);
    }
    .step-dot.done {
      background: var(--green);
      border-color: var(--green);
      color: #fff;
    }
    .step-line {
      flex: 1; height: 2px;
      background: rgba(255,255,255,0.15);
      transition: background 0.3s ease;
      max-width: 80px;
    }
    .step-line.done { background: var(--green); }
    .step-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      padding: 0 4px;
    }
    .step-label {
      font-size: 11px;
      color: rgba(255,255,255,0.45);
      text-align: center;
      flex: 1;
      transition: color 0.3s;
    }
    .step-label.active { color: rgba(255,255,255,0.9); font-weight: 500; }
    .step-label.done { color: rgba(255,255,255,0.65); }

    /* ─── Main ─── */
    main {
      max-width: 680px;
      margin: 0 auto;
      padding: 40px 20px 80px;
    }

    /* ─── Card ─── */
    .card {
      background: var(--white);
      border-radius: 16px;
      box-shadow: var(--shadow);
      padding: 36px 32px;
      animation: fadeUp 0.4s ease;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .card-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 6px;
    }
    .card-sub {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 28px;
      line-height: 1.6;
    }

    /* ─── Options Grid ─── */
    .options-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 10px;
      margin-bottom: 28px;
    }
    .options-grid.two-col {
      grid-template-columns: repeat(2, 1fr);
    }

    .option-btn {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
      padding: 16px;
      background: var(--white);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      font-family: inherit;
    }
    .option-btn:hover {
      border-color: var(--accent);
      background: var(--accent-light);
    }
    .option-btn.selected {
      border-color: var(--accent);
      background: var(--accent-light);
      box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
    }
    .option-icon { font-size: 22px; }
    .option-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.3;
    }
    .option-sub {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.4;
    }

    /* ─── Checkbox options ─── */
    .check-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
    .check-btn {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      background: var(--white);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      font-family: inherit;
      width: 100%;
    }
    .check-btn:hover { border-color: var(--accent); background: var(--accent-light); }
    .check-btn.selected {
      border-color: var(--accent);
      background: var(--accent-light);
    }
    .check-icon { font-size: 20px; flex-shrink: 0; }
    .check-text { flex: 1; }
    .check-label { font-size: 14px; font-weight: 600; color: var(--navy); display: block; }
    .check-desc { font-size: 12px; color: var(--muted); display: block; margin-top: 2px; }
    .check-mark {
      width: 20px; height: 20px;
      border-radius: 6px;
      border: 2px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: all 0.2s;
    }
    .check-btn.selected .check-mark {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      font-size: 12px;
    }

    /* ─── Nav Buttons ─── */
    .nav-row {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
    }
    .btn-back {
      padding: 11px 22px;
      background: var(--white);
      border: 2px solid var(--border);
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
    }
    .btn-back:hover { border-color: var(--navy); color: var(--navy); }
    .btn-next {
      padding: 11px 28px;
      background: var(--accent);
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
      display: flex; align-items: center; gap: 6px;
    }
    .btn-next:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(37,99,235,0.35); }
    .btn-next:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }

    /* ─── Results ─── */
    .results-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .results-header .score-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--green-light);
      color: var(--green);
      border: 1px solid #6ee7b7;
      padding: 6px 18px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .results-header h2 {
      font-size: 22px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 8px;
    }
    .results-header p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
    }

    .section-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 14px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    /* ─── Tool Cards ─── */
    .tool-card {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 12px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
      transition: box-shadow 0.2s;
    }
    .tool-card:hover { box-shadow: var(--shadow); }
    .tool-card.top {
      border-color: var(--accent);
      background: #f0f7ff;
    }
    .tool-rank {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--accent);
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .tool-card.top .tool-rank { background: #f59e0b; }
    .tool-body { flex: 1; }
    .tool-name { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
    .tool-reason { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 12px; }
    .tool-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
    .tag {
      padding: 3px 10px;
      background: var(--accent-light);
      color: var(--accent);
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
    }
    .btn-tool {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 8px 16px;
      background: var(--accent);
      color: #fff;
      border-radius: 7px;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-tool:hover { background: #1d4ed8; }

    /* ─── Subsidy match ─── */
    .subsidy-match {
      background: var(--green-light);
      border: 1px solid #a7f3d0;
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }
    .subsidy-name { font-size: 14px; font-weight: 600; color: var(--navy); }
    .subsidy-meta { font-size: 12px; color: var(--muted); margin-top: 3px; }
    .subsidy-amount {
      font-size: 13px;
      font-weight: 700;
      color: var(--green);
      white-space: nowrap;
    }

    /* ─── CTA ─── */
    .cta-box {
      background: linear-gradient(135deg, var(--navy), var(--indigo));
      border-radius: 16px;
      padding: 32px;
      text-align: center;
      margin-top: 32px;
      color: #fff;
    }
    .cta-box h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
    .cta-box p { font-size: 14px; color: rgba(255,255,255,0.75); margin-bottom: 22px; line-height: 1.7; }
    .btn-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: #fff;
      color: var(--navy);
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.2); }

    /* ─── Hidden ─── */
    [data-step] { display: none; }
    [data-step].active { display: block; }

    @media (max-width: 520px) {
      .card { padding: 24px 18px; }
      .options-grid { grid-template-columns: repeat(2, 1fr); }
      .options-grid.two-col { grid-template-columns: 1fr; }
      .subsidy-match { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

  <header class="site-header">
    <a href="/subsidy-saas-matcher/">✨ 補助金SaaSマッチャー</a>
    <span>›</span>
    <a href="#">無料診断</a>
  </header>

  <div class="hero">
    <div class="hero-badge">✦ 無料・1分でわかる</div>
    <h1>あなたの会社に合う<br /><em>SaaSと補助金</em>を診断</h1>
    <p>業種・規模・お困りごとを選ぶだけ。AIが最適なツールと使える補助金をご提案します。</p>

    <div class="progress-wrap">
      <div class="progress-steps">
        <div class="step-dot active" id="dot-1">1</div>
        <div class="step-line" id="line-1"></div>
        <div class="step-dot" id="dot-2">2</div>
        <div class="step-line" id="line-2"></div>
        <div class="step-dot" id="dot-3">3</div>
        <div class="step-line" id="line-3"></div>
        <div class="step-dot" id="dot-4">4</div>
      </div>
      <div class="step-labels">
        <div class="step-label active" id="label-1">業種</div>
        <div class="step-label" id="label-2">規模</div>
        <div class="step-label" id="label-3">お困りごと</div>
        <div class="step-label" id="label-4">結果</div>
      </div>
    </div>
  </div>

  <main>

    <!-- Step 1: 業種 -->
    <div data-step="1" class="active">
      <div class="card">
        <div class="card-title">業種を教えてください</div>
        <div class="card-sub">最も近いものを1つお選びください。</div>
        <div class="options-grid">
          <button class="option-btn" data-val="construction" onclick="select(this, 1)">
            <span class="option-icon">🏗️</span>
            <span class="option-label">建設業</span>
          </button>
          <button class="option-btn" data-val="retail" onclick="select(this, 1)">
            <span class="option-icon">🛒</span>
            <span class="option-label">小売・飲食</span>
          </button>
          <button class="option-btn" data-val="medical" onclick="select(this, 1)">
            <span class="option-icon">🏥</span>
            <span class="option-label">医療・福祉</span>
          </button>
          <button class="option-btn" data-val="service" onclick="select(this, 1)">
            <span class="option-icon">✂️</span>
            <span class="option-label">美容・サービス</span>
          </button>
          <button class="option-btn" data-val="it" onclick="select(this, 1)">
            <span class="option-icon">💻</span>
            <span class="option-label">IT・情報サービス</span>
          </button>
          <button class="option-btn" data-val="logistics" onclick="select(this, 1)">
            <span class="option-icon">🚚</span>
            <span class="option-label">運輸・物流</span>
          </button>
          <button class="option-btn" data-val="manufacturing" onclick="select(this, 1)">
            <span class="option-icon">🏭</span>
            <span class="option-label">製造業</span>
          </button>
          <button class="option-btn" data-val="other" onclick="select(this, 1)">
            <span class="option-icon">🏢</span>
            <span class="option-label">その他</span>
          </button>
        </div>
        <div class="nav-row">
          <button class="btn-next" id="next-1" disabled onclick="goTo(2)">次へ →</button>
        </div>
      </div>
    </div>

    <!-- Step 2: 従業員数 -->
    <div data-step="2">
      <div class="card">
        <div class="card-title">従業員数を教えてください</div>
        <div class="card-sub">補助金の対象要件に関わります。</div>
        <div class="options-grid two-col">
          <button class="option-btn" data-val="micro" onclick="select(this, 2)">
            <span class="option-icon">👤</span>
            <span class="option-label">1〜5名</span>
            <span class="option-sub">個人事業主・小規模</span>
          </button>
          <button class="option-btn" data-val="small" onclick="select(this, 2)">
            <span class="option-icon">👥</span>
            <span class="option-label">6〜20名</span>
            <span class="option-sub">小規模事業者</span>
          </button>
          <button class="option-btn" data-val="medium" onclick="select(this, 2)">
            <span class="option-icon">🏢</span>
            <span class="option-label">21〜50名</span>
            <span class="option-sub">中小企業</span>
          </button>
          <button class="option-btn" data-val="large" onclick="select(this, 2)">
            <span class="option-icon">🏬</span>
            <span class="option-label">51名以上</span>
            <span class="option-sub">中堅・大企業</span>
          </button>
        </div>
        <div class="nav-row">
          <button class="btn-back" onclick="goTo(1)">← 戻る</button>
          <button class="btn-next" id="next-2" disabled onclick="goTo(3)">次へ →</button>
        </div>
      </div>
    </div>

    <!-- Step 3: お困りごと -->
    <div data-step="3">
      <div class="card">
        <div class="card-title">お困りごとを教えてください</div>
        <div class="card-sub">当てはまるものをすべてお選びください（複数可）。</div>
        <div class="check-options">
          <button class="check-btn" data-val="accounting" onclick="toggle(this, 3)">
            <span class="check-icon">📊</span>
            <span class="check-text">
              <span class="check-label">経理・会計の手間を減らしたい</span>
              <span class="check-desc">帳簿・仕訳・確定申告の自動化</span>
            </span>
            <span class="check-mark"></span>
          </button>
          <button class="check-btn" data-val="invoice" onclick="toggle(this, 3)">
            <span class="check-icon">🧾</span>
            <span class="check-text">
              <span class="check-label">インボイス・電帳法に対応したい</span>
              <span class="check-desc">適格請求書・電子保存への対応</span>
            </span>
            <span class="check-mark"></span>
          </button>
          <button class="check-btn" data-val="expense" onclick="toggle(this, 3)">
            <span class="check-icon">💳</span>
            <span class="check-text">
              <span class="check-label">経費精算・立替払いを楽にしたい</span>
              <span class="check-desc">領収書管理・承認フローの効率化</span>
            </span>
            <span class="check-mark"></span>
          </button>
          <button class="check-btn" data-val="payroll" onclick="toggle(this, 3)">
            <span class="check-icon">👔</span>
            <span class="check-text">
              <span class="check-label">給与計算・勤怠管理を効率化したい</span>
              <span class="check-desc">給与明細・勤怠記録のデジタル化</span>
            </span>
            <span class="check-mark"></span>
          </button>
          <button class="check-btn" data-val="cashflow" onclick="toggle(this, 3)">
            <span class="check-icon">💰</span>
            <span class="check-text">
              <span class="check-label">資金繰り・キャッシュフローを改善したい</span>
              <span class="check-desc">入出金管理・資金調達の最適化</span>
            </span>
            <span class="check-mark"></span>
          </button>
        </div>
        <div class="nav-row">
          <button class="btn-back" onclick="goTo(2)">← 戻る</button>
          <button class="btn-next" id="next-3" disabled onclick="showResults()">診断する →</button>
        </div>
      </div>
    </div>

    <!-- Step 4: 結果 -->
    <div data-step="4" id="results-panel">
    </div>

  </main>

  <script>
    const answers = { industry: null, size: null, concerns: [] };

    function trackUrl(baseUrl, toolSlug) {
      return `${baseUrl}&utm_source=diagnose&utm_medium=result&utm_content=${toolSlug}`;
    }
    const CONSULT_URL = 'https://px.a8.net/svt/ejp?a8mat=4B1DXN+ADAT2Q+4EKW+BX3J6&utm_source=diagnose&utm_medium=cta&utm_content=consult';
    const SUBSIDY_LIST_URL = '/subsidy-saas-matcher/subsidies/?utm_source=diagnose&utm_medium=cta&utm_content=subsidy_list';

    function select(btn, step) {
      btn.closest('.card').querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      if (step === 1) answers.industry = btn.dataset.val;
      if (step === 2) answers.size = btn.dataset.val;
      document.getElementById('next-' + step).disabled = false;
    }

    function toggle(btn, step) {
      btn.classList.toggle('selected');
      const mark = btn.querySelector('.check-mark');
      if (btn.classList.contains('selected')) {
        mark.textContent = '✓';
        if (!answers.concerns.includes(btn.dataset.val)) answers.concerns.push(btn.dataset.val);
      } else {
        mark.textContent = '';
        answers.concerns = answers.concerns.filter(v => v !== btn.dataset.val);
      }
      document.getElementById('next-3').disabled = answers.concerns.length === 0;
    }

    function goTo(step) {
      document.querySelectorAll('[data-step]').forEach(el => el.classList.remove('active'));
      document.querySelector('[data-step="' + step + '"]').classList.add('active');
      updateProgress(step);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateProgress(current) {
      [1,2,3,4].forEach(i => {
        const dot = document.getElementById('dot-' + i);
        const label = document.getElementById('label-' + i);
        const line = document.getElementById('line-' + i);
        if (dot) {
            dot.className = 'step-dot' + (i < current ? ' done' : i === current ? ' active' : '');
            dot.textContent = i < current ? '✓' : i;
        }
        if (label) label.className = 'step-label' + (i < current ? ' done' : i === current ? ' active' : '');
        if (line) line.className = 'step-line' + (i < current ? ' done' : '');
      });
    }

    function buildReason(tool, concerns, industry) {
      const industryLabel = {
        construction:'建設業', retail:'小売・飲食', medical:'医療・福祉',
        service:'美容・サービス', it:'IT・情報サービス', logistics:'運輸・物流',
        manufacturing:'製造業', other:null
      }[industry];

      const matched = tool.concerns.filter(c => concerns.includes(c));
      const concernLabel = {
        accounting:'経理・会計の効率化',
        invoice:'インボイス・電帳法対応',
        expense:'経費精算の自動化',
        payroll:'給与計算・勤怠管理',
        cashflow:'キャッシュフロー改善'
      };

      const base = {
        'freee-accounting': {
          accounting: '帳簿・仕訳を銀行口座と自動連携で大幅に削減できます。',
          invoice: 'インボイス制度・電帳法への対応を自動化し、手作業ゼロを実現します。',
          default: '会計業務のDXを最短で実現できるクラウド会計ソフトです。'
        },
        'moneyforward-tax': {
          accounting: '会計・給与・経費をひとつのIDで管理でき、業務横断での効率化が可能です。',
          payroll: '給与計算から勤怠管理まで一元化。担当者の作業時間を大幅に削減します。',
          expense: '経費申請から承認・仕訳まで全自動。立替精算のストレスをなくします。',
          default: '複数の業務をひとつのクラウドで完結できる統合型サービスです。'
        },
        'recruit-tatemae': {
          expense: 'お手元の請求書を最短即日で現金化。急な出費にも対応可能です。',
          cashflow: '補助金入金までの立替資金を、お手元の請求書で即日現金化。資金ショートを防ぎます。',
          default: 'キャッシュフローを劇的に改善するファクタリングサービスです。'
        },
        'yayoi-accounting-next': {
          accounting: '使い慣れた弥生のインターフェースで、クラウド移行のハードルを最小化できます。',
          invoice: 'インボイス・電帳法対応も完備。弥生の豊富なサポートで安心して移行できます。',
          default: '30年以上の実績を持つ弥生のクラウド版。初めての会計ソフトにも最適です。'
        }
      };

      const toolBase = base[tool.slug] || {};
      const reasonText = matched.map(c => toolBase[c]).find(Boolean) || toolBase.default || tool.reason;

      const prefix = industryLabel ? `${industryLabel}の` : '';
      const concernStr = matched.map(c => concernLabel[c]).filter(Boolean).join('・');
      const highlight = concernStr ? `「${concernStr}」のご要望に対して、` : '';

      return `${prefix}${highlight}${reasonText}`;
    }

    const TOOLS = [
      {
        slug: 'freee-accounting',
        name: 'freee会計',
        icon: '🟢',
        tags: ['会計', 'インボイス', '電帳法', '確定申告'],
        concerns: ['accounting', 'invoice'],
        baseUrl: 'https://px.a8.net/svt/ejp?a8mat=4AZS0X+6GSIB6+3SPO+9FGXPF',
        reason: '銀行・カード自動連携で仕訳を自動化。インボイス・電帳法にも完全対応。',
      },
      {
        slug: 'moneyforward-tax',
        name: 'マネーフォワード クラウド',
        icon: '🔵',
        tags: ['会計', '給与', '経費', 'インボイス'],
        concerns: ['accounting', 'payroll', 'invoice', 'expense'],
        baseUrl: 'https://px.a8.net/svt/ejp?a8mat=4AZS0X+6J68QA+4JGQ+BWVTE',
        reason: '会計・給与・勤怠・経費を1プラットフォームで完結。',
      },
      {
        slug: 'yayoi-accounting-next',
        name: '弥生シリーズ',
        icon: '🔴',
        tags: ['会計', '確定申告', 'インボイス'],
        concerns: ['accounting', 'invoice'],
        baseUrl: 'https://px.a8.net/svt/ejp?a8mat=4B1O1Q+7BR1RM+35XE+6IP2Q',
        reason: '老舗会計ソフトのクラウド版。初めての会計ソフトにも最適。',
      },
      {
        slug: 'recruit-tatemae',
        name: 'リクルート 請求書立替払い',
        icon: '💳',
        tags: ['キャッシュフロー', '資金調達', '即日現金化'],
        concerns: ['cashflow', 'expense'],
        baseUrl: 'https://px.a8.net/svt/ejp?a8mat=4AZS0X+6GSIB6+3SPO+9FGXPF',
        reason: '補助金入金までの立替資金を、お手元の請求書で即日現金化。資金ショートを防ぎます。',
      },
    ];

    const SUBSIDY_HINTS = [
      { name: 'IT導入補助金（インボイス枠）', max: '350,000円', concerns: ['accounting', 'invoice'], sizes: ['micro','small','medium'] },
      { name: '小規模事業者持続化補助金', max: '2,000,000円', concerns: ['accounting', 'expense', 'invoice'], sizes: ['micro','small'] },
      { name: 'IT導入補助金（通常枠）', max: '4,500,000円', concerns: ['accounting', 'payroll', 'expense', 'invoice', 'cashflow'], sizes: ['small','medium','large'] },
      { name: '業務改善助成金', max: '6,000,000円', concerns: ['payroll'], sizes: ['micro','small','medium'] },
    ];

    function showResults() {
      const scored = TOOLS.map(tool => {
        const overlap = tool.concerns.filter(c => answers.concerns.includes(c)).length;
        const score = Math.round((overlap / tool.concerns.length) * 80 + (answers.concerns.includes(tool.concerns[0]) ? 20 : 0));
        return { ...tool, score: Math.min(score, 100) };
      }).filter(t => t.score > 0).sort((a, b) => b.score - a.score);

      const matchedSubsidies = SUBSIDY_HINTS.filter(s =>
        s.concerns.some(c => answers.concerns.includes(c)) &&
        s.sizes.includes(answers.size)
      );

      const industryLabel = {
        construction:'建設業', retail:'小売・飲食', medical:'医療・福祉',
        service:'美容・サービス', it:'IT・情報サービス', logistics:'運輸・物流',
        manufacturing:'製造業', other:'その他'
      }[answers.industry] || '';

      const sizeLabel = {
        micro:'1〜5名', small:'6〜20名', medium:'21〜50名', large:'51名以上'
      }[answers.size] || '';

      let html = `
        <div class="card">
          <div class="results-header">
            <div class="score-badge">✦ 診断完了</div>
            <h2>${industryLabel}・${sizeLabel}のあなたへ</h2>
            <p>${answers.concerns.length}つのお困りごとに対して、<strong>${scored.length}件のSaaSツール</strong>と<strong>${matchedSubsidies.length}件の補助金</strong>が見つかりました。</p>
          </div>

          <div class="section-label">おすすめ SaaS ツール</div>
      `;

      scored.slice(0, 3).forEach((tool, i) => {
        const dynamicReason = buildReason(tool, answers.concerns, answers.industry);
        const trackedUrl = trackUrl(tool.baseUrl, tool.slug);
        html += `
          <div class="tool-card ${i === 0 ? 'top' : ''}">
            <div class="tool-rank">${i === 0 ? '★' : i + 1}</div>
            <div class="tool-body">
              <div class="tool-name">${tool.icon} ${tool.name}</div>
              <div class="tool-reason">${dynamicReason}</div>
              <div class="tool-tags">${tool.tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>
              <a class="btn-tool" href="${trackedUrl}" target="_blank" rel="noopener">公式サイトへ進む →</a>
            </div>
          </div>
        `;
      });

      if (matchedSubsidies.length > 0) {
        html += `<div class="section-label" style="margin-top:28px">使える可能性がある補助金</div>`;
        matchedSubsidies.forEach(s => {
          html += `
            <div class="subsidy-match">
              <div>
                <div class="subsidy-name">${s.name}</div>
                <div class="subsidy-meta">SaaSツール導入費用に活用可能</div>
              </div>
              <div class="subsidy-amount">最大補助額 ${s.max}</div>
            </div>
          `;
        });
      }

      html += `
          <div class="cta-box">
            <h3>💴 補助金申請、プロに相談してみませんか？</h3>
            <p>申請手続きは複雑です。専門家に相談すれば採択率が大幅にアップします。<br />オンラインで即日相談可能です。</p>
            <div style="display:flex;flex-direction:column;gap:10px;align-items:center;">
              <a class="btn-cta" href="${CONSULT_URL}" target="_blank" rel="noopener">
                💬 完全無料で専門家に相談する →
              </a>
              <a href="${SUBSIDY_LIST_URL}" style="color:rgba(255,255,255,0.7);font-size:13px;text-decoration:underline;">
                まず補助金の一覧を見てみる
              </a>
            </div>
          </div>

          <div style="margin-top:20px;text-align:center;">
            <button onclick="restart()" style="background:none;border:none;color:var(--muted);font-size:13px;cursor:pointer;text-decoration:underline;font-family:inherit;">
              もう一度診断する
            </button>
          </div>
        </div>
      `;

      document.getElementById('results-panel').innerHTML = html;
      goTo(4);
    }

    function restart() {
      answers.industry = null;
      answers.size = null;
      answers.concerns = [];
      document.querySelectorAll('.option-btn, .check-btn').forEach(b => b.classList.remove('selected'));
      document.querySelectorAll('.check-mark').forEach(m => m.textContent = '');
      document.querySelectorAll('.btn-next').forEach(b => b.disabled = true);
      goTo(1);
    }
  </script>

</body>
</html>
