---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatCurrency } from '../../lib/normalize';
import fs from 'fs';
import path from 'path';

const base = import.meta.env.BASE_URL;
const category = 'accounting';

const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsidies", e);
}

const categorySubsidies = subsidies.filter(s => s.tags?.includes(category));
---

<BaseLayout title="経理・会計ソフト導入 | 補助金SaaSマッチャー">
  <div class="container py-12">
    <h1 class="text-3xl font-bold mb-8">経理・会計DXに使える補助金</h1>
    <div class="grid gap-6">
      {categorySubsidies.map(s => (
        <div class="glass-card">
          <h3><a href={`${base}subsidies/${s.id}/`}>{s.title}</a></h3>
          <p>{formatCurrency(s.max_limit)}</p>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
