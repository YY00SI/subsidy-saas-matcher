---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

const category = 'accounting';
const label = '会計ソフト導入';

// processedデータ読み込み
const dataPath = path.join(process.cwd(), 'data', 'processed', 'subsidies.json');
let subsidies = [];
try {
  subsidies = JSON.parse(fs.readFileSync(dataPath, 'utf8'));
} catch (e) {
  console.warn("Failed to load subsidies in accounting.astro", e);
}

// このカテゴリに属する補助金を抽出
const categorySubsidies = subsidies.filter(s => s.tags?.includes(category));

// おすすめツールの読み込み
const toolsPath = path.join(process.cwd(), 'data', 'tools.json');
let tools = [];
try {
  const allTools = JSON.parse(fs.readFileSync(toolsPath, 'utf8'));
  tools = allTools.filter(t => t.category === category);
} catch (e) {
  console.warn("Failed to load tools in accounting.astro", e);
}
---

<BaseLayout 
  title={`${label}に使える補助金マッチング`} 
  description={`経理・会計業務の効率化やクラウド会計ソフト導入に活用できる補助金の一覧と、おすすめツールを紹介します。`}
>
  <div class="hero-section">
    <div class="tags"><span class="tag">ニーズ別ガイド</span></div>
    <h1>{label}を補助金でもっと身近に</h1>
    <p class="lead">面倒な経理業務を自動化。クラウド会計ソフトの導入費用は補助金で補填できる可能性があります。</p>
  </div>

  <section class="guide-section">
    <h2>なぜ会計ソフト導入に補助金が使えるの？</h2>
    <div class="card guide-card">
      <p>
        政府は中小企業の「デジタル化・DX」を強力に推進しています。
        特に会計ソフトは、経営状況の可視化や生産性向上に直結するため、多くの補助金において「ITツール」として認められています。
        インボイス制度や電子帳簿保存法への対応も、補助金活用の大きな動機となります。
      </p>
    </div>
  </section>

  <div class="content-grid">
    <div class="left-col">
      <section class="subsidies-section">
        <h2>おすすめの補助金</h2>
        <div class="subsidy-list">
          {categorySubsidies.length > 0 ? categorySubsidies.map(s => (
            <div class="card s-card">
              <h3><a href={`/subsidies/${s.id}`}>{s.title}</a></h3>
              <p>{s.use_purpose}</p>
              <div class="s-footer">
                <span class="limit">上限: {s.max_limit}</span>
                <span class="rate">補助率: {s.rate}</span>
              </div>
            </div>
          )) : (
            <p>現在、このカテゴリに特化した補助金情報は準備中です。</p>
          )}
        </div>
      </section>
    </div>

    <aside class="right-col">
      <section class="tools-section">
        <h2>おすすめの会計ソフト</h2>
        <div class="tool-list">
          {tools.map(t => (
            <div class="card t-card">
              <h3>{t.name}</h3>
              <p>{t.strengths}</p>
              <div class="t-actions">
                <a href={t.affiliate_url} target="_blank" rel="sponsored noopener noreferrer" class="btn btn-primary">公式サイトで見る</a>
                <a href={`/tools/${t.slug}`} class="detail-link">詳しく解説</a>
              </div>
            </div>
          ))}
        </div>
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  .hero-section { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); padding: 4rem 2rem; border-radius: 20px; text-align: center; margin-bottom: 3rem; }
  .hero-section h1 { font-size: 2.5rem; margin: 1rem 0; }
  .lead { max-width: 700px; margin: 0 auto; color: #475569; font-size: 1.1rem; }

  .guide-section { margin-bottom: 4rem; }
  .guide-card { background: white; border-left: 6px solid #3b82f6; padding: 2rem; }

  .content-grid { display: grid; grid-template-columns: 1fr 340px; gap: 3rem; }
  @media (max-width: 800px) { .content-grid { grid-template-columns: 1fr; } }

  .subsidies-section h2, .tools-section h2 { margin-bottom: 1.5rem; font-size: 1.5rem; }
  
  .s-card { margin-bottom: 1rem; }
  .s-card h3 a { color: #0f172a; text-decoration: none; }
  .s-card h3 a:hover { color: #3b82f6; }
  .s-footer { margin-top: 1rem; display: flex; gap: 1rem; font-size: 0.85rem; font-weight: bold; color: #64748b; }

  .t-card { margin-bottom: 1rem; border-top: 4px solid #3b82f6; }
  .t-card h3 { margin: 0 0 0.75rem 0; font-size: 1.25rem; }
  .t-card p { font-size: 0.85rem; color: #475569; margin-bottom: 1.5rem; }
  .t-actions { display: flex; flex-direction: column; gap: 0.75rem; }
  .detail-link { text-align: center; font-size: 0.8rem; color: #64748b; text-decoration: none; }
  .detail-link:hover { text-decoration: underline; }
</style>
